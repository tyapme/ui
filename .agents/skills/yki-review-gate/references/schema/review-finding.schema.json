{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Phase 1: 各 reviewer が出す指摘事項の一覧（スコアなし）",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reviewer_id",
    "reviewer_name",
    "scope_summary",
    "findings"
  ],
  "properties": {
    "reviewer_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_name": {
      "type": "string",
      "minLength": 1
    },
    "scope_summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "detail"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Finding の一意識別子（例: gr1-001, ra-001）",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string"
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
